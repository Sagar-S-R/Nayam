# ═══════════════════════════════════════════════════════════════════════════════
# NAYAM Frontend — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env.local and update values for your environment.
# DO NOT commit .env.local or .env with secrets to version control.
#
# For more info, see: https://nextjs.org/docs/basic-features/environment-variables
#

# ═══════════════════════════════════════════════════════════════════════════════
# API Configuration
# ═══════════════════════════════════════════════════════════════════════════════
#
# NEXT_PUBLIC_API_URL
#   • Backend base URL (including /api/v1 path)
#   • This variable is embedded in the browser bundle (NEXT_PUBLIC_ prefix)
#   • Used by all API calls via lib/api.ts
#   • Change this when switching between local backend and Cloudflare tunnel
#
# Local Development:
#   NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
#
# Cloudflare Tunnel (Hackathon Demo):
#   NEXT_PUBLIC_API_URL=https://your-tunnel.trycloudflare.com/api/v1
#
# Production (Vercel):
#   Set in Vercel Dashboard → Settings → Environment Variables
#   NEXT_PUBLIC_API_URL=https://api.production.com/api/v1
#

NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
