# ===========================================
# NAYAM — Environment Configuration Template
# ===========================================
# Copy this file to .env and fill in values.
# NEVER commit .env to version control.
# ===========================================

# Application
APP_NAME=NAYAM
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true

# Database
DATABASE_URL=postgresql://nayam_user:nayam_password@localhost:5432/nayam_db

# JWT Authentication
JWT_SECRET_KEY=CHANGE_ME_TO_A_SECURE_RANDOM_STRING
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# File Uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
