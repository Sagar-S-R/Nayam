# ===========================================
# NAYAM — Git Ignore Rules
# ===========================================

# Environment
.env
venv/
.venv/
env/
.txt

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Testing
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# Uploads (keep directory, ignore contents)
uploads/*
!uploads/.gitkeep

# OS
.DS_Store
Thumbs.db

# Alembic
alembic/versions/__pycache__/
